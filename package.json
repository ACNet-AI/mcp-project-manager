{
  "name": "mcp-project-manager",
  "version": "1.0.0",
  "description": "Automated management of MCP server project registration, validation and publishing",
  "author": "ACNet-AI <agencollabnet@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/mcp-servers-hub/mcp-project-manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-servers-hub/mcp-project-manager.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-servers-hub/mcp-project-manager/issues"
  },
  "keywords": [
    "mcp",
    "github-app",
    "automation",
    "project-management",
    "webhook",
    "typescript"
  ],
  "main": "lib/index.js",
  "engines": {
    "node": ">= 18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec \"npm run build && npm start\"",
    "start": "probot run ./lib/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --testResultsProcessor=jest-junit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf lib",
    "prebuild": "npm run clean",
    "prepare": "npm run build",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage"
  },
  "dependencies": {
    "probot": "^13.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.19.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "audit-ci": "^7.1.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "lib",
      "test"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": false,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "quoteProps": "as-needed",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "bracketSameLine": false,
    "proseWrap": "preserve"
  }
}
